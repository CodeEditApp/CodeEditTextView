{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView"]]},"metadata":{"roleHeading":"Instance Method","symbolKind":"method","title":"fractionOfDistanceThroughGlyph(for:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"for"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint","text":"NSPoint"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat","kind":"typeIdentifier"}],"extendedModule":"CodeEditTextView","role":"symbol","modules":[{"name":"CodeEditTextView"}],"externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:"},"variants":[{"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"kind":"text","text":" "},{"text":"point","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@NSPoint","text":"NSPoint","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"parameters":[{"name":"point","content":[{"type":"paragraph","inlineContent":[{"text":"The point to test.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint"},{"type":"text","text":" "},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"1 if it’s to the right or below)."}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or"},{"type":"text","text":" "},{"text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage","type":"text"},{"type":"text","text":" "},{"text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1.","type":"text"}]},{"inlineContent":[{"text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this"},{"text":" ","type":"text"},{"text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"selection or placing the insertion point."}],"type":"paragraph"}]}],"references":{"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView":{"abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"kind":"symbol","title":"CodeEditTextView","role":"collection","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView","url":"\/documentation\/codeedittextview","type":"topic"},"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"role":"symbol","url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@NSPoint","kind":"typeIdentifier","text":"NSPoint"},{"kind":"text","text":") -> "},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"type":"topic","abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lies."}],"title":"fractionOfDistanceThroughGlyph(for:)","kind":"symbol"},"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextView":{"navigatorTitle":[{"text":"TextView","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"A view that draws and handles user interactions with text."},{"type":"text","text":" "},{"type":"text","text":"Optimized for line-based documents, does not attempt to have feature parity with "},{"type":"codeVoice","code":"NSTextView"},{"type":"text","text":"."}],"identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView","kind":"symbol","title":"TextView","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TextView","kind":"identifier"}],"role":"symbol","url":"\/documentation\/codeedittextview\/textview"}}}