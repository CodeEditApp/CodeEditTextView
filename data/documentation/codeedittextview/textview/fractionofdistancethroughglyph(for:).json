{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"sections":[],"kind":"symbol","metadata":{"modules":[{"name":"CodeEditTextView"}],"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"NSPoint","preciseIdentifier":"c:@T@NSPoint"},{"kind":"text","text":") -> "},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"roleHeading":"Instance Method","title":"fractionOfDistanceThroughGlyph(for:)","externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:","extendedModule":"CodeEditTextView","role":"symbol"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"kind":"text","text":"("},{"text":"for","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"point","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint","text":"NSPoint"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier","text":"CGFloat"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"point","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The point to test."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"inlineContent":[{"type":"text","text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint"},{"text":" ","type":"text"},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"1 if it’s to the right or below)."}],"type":"paragraph"}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or"},{"text":" ","type":"text"},{"text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage","type":"text"},{"type":"text","text":" "},{"text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and"},{"text":" ","type":"text"},{"text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a"},{"type":"text","text":" "},{"type":"text","text":"selection or placing the insertion point."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"]}],"abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"type":"text","text":" "},{"text":"lies.","type":"text"}],"references":{"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"kind":"symbol","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"NSPoint","preciseIdentifier":"c:@T@NSPoint","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat","kind":"typeIdentifier"}],"title":"fractionOfDistanceThroughGlyph(for:)","abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"type":"text","text":" "},{"text":"lies.","type":"text"}],"role":"symbol","type":"topic"},"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations","url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations","kind":"article","title":"NSTextInputClient Implementations","role":"collectionGroup","abstract":[],"type":"topic"},"doc://codeedittextview.CodeEditTextView/documentation