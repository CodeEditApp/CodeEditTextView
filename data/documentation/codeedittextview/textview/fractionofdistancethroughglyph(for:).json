{"hierarchy":{"paths":[["doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"identifier":{"url":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"]}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@NSPoint","text":"NSPoint","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"}],"role":"symbol","title":"fractionOfDistanceThroughGlyph(for:)","roleHeading":"Instance Method","extendedModule":"CodeEditTextView","externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:","modules":[{"name":"CodeEditTextView"}],"symbolKind":"method"},"abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"point","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"NSPoint","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier","text":"CGFloat"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The point to test."}],"type":"paragraph"}],"name":"point"}]},{"kind":"content","content":[{"text":"Return Value","level":2,"anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint"},{"type":"text","text":" "},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"text":" ","type":"text"},{"text":"1 if it’s to the right or below).","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage"},{"type":"text","text":" "},{"type":"text","text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t"},{"type":"text","text":" "},{"type":"text","text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and"},{"text":" ","type":"text"},{"text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this","type":"text"},{"type":"text","text":" "},{"text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"selection or placing the insertion point."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"references":{"doc://CodeEditTextView/documentation/CodeEditTextView":{"kind":"symbol","title":"CodeEditTextView","abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"url":"\/documentation\/codeedittextview","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","role":"collection","type":"topic"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"text":"NSPoint","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint"},{"kind":"text","text":") -> "},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"role":"symbol","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"text":" ","type":"text"},{"type":"text","text":"lies."}],"type":"topic","title":"fractionOfDistanceThroughGlyph(for:)","url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","kind":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"TextView","kind":"identifier"}],"kind":"symbol","title":"TextView","url":"\/documentation\/codeedittextview\/textview","type":"topic","navigatorTitle":[{"text":"TextView","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A view that draws and handles user interactions with text."},{"type":"text","text":" "},{"type":"text","text":"Optimized for line-based documents, does not attempt to have feature parity with "},{"type":"codeVoice","code":"NSTextView"},{"type":"text","text":"."}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"kind":"article","title":"NSTextInputClient Implementations","type":"topic","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations","url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations","role":"collectionGroup","abstract":[]}}}