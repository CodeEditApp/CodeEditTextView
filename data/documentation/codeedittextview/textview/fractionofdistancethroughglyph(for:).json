{"abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"point"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@NSPoint","text":"NSPoint","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"point","content":[{"inlineContent":[{"text":"The point to test.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"inlineContent":[{"text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint","type":"text"},{"text":" ","type":"text"},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"text":" ","type":"text"},{"text":"1 if it’s to the right or below).","type":"text"}],"type":"paragraph"}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or"},{"text":" ","type":"text"},{"text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t"},{"type":"text","text":" "},{"type":"text","text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1."}]},{"inlineContent":[{"text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this"},{"text":" ","type":"text"},{"type":"text","text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a"},{"type":"text","text":" "},{"type":"text","text":"selection or placing the insertion point."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"NSPoint","preciseIdentifier":"c:@T@NSPoint"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier","text":"CGFloat"}],"role":"symbol","modules":[{"name":"CodeEditTextView"}],"title":"fractionOfDistanceThroughGlyph(for:)","extendedModule":"CodeEditTextView","symbolKind":"method"},"sections":[],"references":{"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint","text":"NSPoint"},{"text":") -> ","kind":"text"},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lies."}],"title":"fractionOfDistanceThroughGlyph(for:)","type":"topic"},"doc://CodeEditTextView/documentation/CodeEditTextView":{"type":"topic","role":"collection","abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","title":"CodeEditTextView","url":"\/documentation\/codeedittextview","kind":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"abstract":[],"url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations","title":"NSTextInputClient Implementations","kind":"article","type":"topic","role":"collectionGroup","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView":{"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","url":"\/documentation\/codeedittextview\/textview","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TextView"}],"navigatorTitle":[{"text":"TextView","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TextView","abstract":[{"type":"text","text":"A view that draws and handles user interactions with text."},{"type":"text","text":" "},{"text":"Optimized for line-based documents, does not attempt to have feature parity with ","type":"text"},{"type":"codeVoice","code":"NSTextView"},{"type":"text","text":"."}],"role":"symbol"}}}