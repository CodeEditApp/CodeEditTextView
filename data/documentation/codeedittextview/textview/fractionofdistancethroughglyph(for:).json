{"identifier":{"url":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"kind":"text","text":"("},{"text":"for","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"point","kind":"internalParam"},{"kind":"text","text":": "},{"text":"NSPoint","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"point","content":[{"inlineContent":[{"text":"The point to test.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint"},{"text":" ","type":"text"},{"type":"text","text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;"},{"type":"text","text":" "},{"type":"text","text":"1 if it’s to the right or below)."}]}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage"},{"text":" ","type":"text"},{"type":"text","text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t"},{"text":" ","type":"text"},{"text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and"},{"type":"text","text":" "},{"type":"text","text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this"},{"text":" ","type":"text"},{"text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"selection or placing the insertion point."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"symbol","externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:","modules":[{"name":"CodeEditTextView"}],"extendedModule":"CodeEditTextView","symbolKind":"method","roleHeading":"Instance Method","title":"fractionOfDistanceThroughGlyph(for:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint","text":"NSPoint"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}]},"abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"type":"text","text":" "},{"text":"lies.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://CodeEditTextView/documentation/CodeEditTextView/TextView":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TextView","kind":"identifier"}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","url":"\/documentation\/codeedittextview\/textview","role":"symbol","title":"TextView","type":"topic","abstract":[{"text":"A view that draws and handles user interactions with text.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Optimized for line-based documents, does not attempt to have feature parity with "},{"type":"codeVoice","code":"NSTextView"},{"type":"text","text":"."}],"kind":"symbol","navigatorTitle":[{"text":"TextView","kind":"identifier"}]},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"kind":"article","url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations","abstract":[],"type":"topic","title":"NSTextInputClient Implementations","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations","role":"collectionGroup"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"type":"topic","url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"NSPoint","preciseIdentifier":"c:@T@NSPoint"},{"text":") -> ","kind":"text"},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"title":"fractionOfDistanceThroughGlyph(for:)","abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","role":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView":{"role":"collection","url":"\/documentation\/codeedittextview","title":"CodeEditTextView","type":"topic","abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"kind":"symbol","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView"}}}