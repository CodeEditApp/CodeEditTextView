{"sections":[],"abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"point"},{"text":": ","kind":"text"},{"text":"NSPoint","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The point to test."}]}],"name":"point"}]},{"content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"inlineContent":[{"text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint","type":"text"},{"type":"text","text":" "},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"1 if it’s to the right or below)."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage"},{"text":" ","type":"text"},{"type":"text","text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t"},{"type":"text","text":" "},{"type":"text","text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1."}]},{"type":"paragraph","inlineContent":[{"text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and","type":"text"},{"type":"text","text":" "},{"text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a"},{"type":"text","text":" "},{"type":"text","text":"selection or placing the insertion point."}]}]}],"metadata":{"symbolKind":"method","extendedModule":"CodeEditTextView","title":"fractionOfDistanceThroughGlyph(for:)","modules":[{"name":"CodeEditTextView"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"kind":"text","text":"("},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@NSPoint","text":"NSPoint","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier","text":"CGFloat"}],"externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:","roleHeading":"Instance Method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"references":{"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"role":"collectionGroup","url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations","title":"NSTextInputClient Implementations","abstract":[],"kind":"article","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations","type":"topic"},"doc://CodeEditTextView/documentation/CodeEditTextView":{"title":"CodeEditTextView","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","url":"\/documentation\/codeedittextview","kind":"symbol","type":"topic","role":"collection","abstract":[{"text":"A text editor designed to edit code documents.","type":"text"}]},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TextView"}],"abstract":[{"text":"A view that draws and handles user interactions with text.","type":"text"},{"type":"text","text":" "},{"text":"Optimized for line-based documents, does not attempt to have feature parity with ","type":"text"},{"type":"codeVoice","code":"NSTextView"},{"text":".","type":"text"}],"url":"\/documentation\/codeedittextview\/textview","title":"TextView","type":"topic","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TextView"}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","role":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","type":"topic","title":"fractionOfDistanceThroughGlyph(for:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@NSPoint","text":"NSPoint","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"}],"url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","kind":"symbol","abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"type":"text","text":" "},{"text":"lies.","type":"text"}],"role":"symbol"}}}