{"hierarchy":{"paths":[["doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"identifier":{"url":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"CodeEditTextView"}],"title":"fractionOfDistanceThroughGlyph(for:)","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"text":": ","kind":"text"},{"text":"NSPoint","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint"},{"text":") -> ","kind":"text"},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"role":"symbol","extendedModule":"CodeEditTextView","externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:"},"sections":[],"abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"for"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"point"},{"text":": ","kind":"text"},{"text":"NSPoint","preciseIdentifier":"c:@T@NSPoint","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The point to test."}],"type":"paragraph"}],"name":"point"}]},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint","type":"text"},{"type":"text","text":" "},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"text":" ","type":"text"},{"text":"1 if it’s to the right or below).","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or"},{"text":" ","type":"text"},{"type":"text","text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage"},{"type":"text","text":" "},{"type":"text","text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t"},{"text":" ","type":"text"},{"text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and","type":"text"},{"text":" ","type":"text"},{"text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a"},{"text":" ","type":"text"},{"type":"text","text":"selection or placing the insertion point."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"]}],"references":{"doc://CodeEditTextView/documentation/CodeEditTextView/TextView":{"navigatorTitle":[{"text":"TextView","kind":"identifier"}],"type":"topic","kind":"symbol","title":"TextView","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TextView"}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","abstract":[{"type":"text","text":"A view that draws and handles user interactions with text."},{"type":"text","text":" "},{"type":"text","text":"Optimized for line-based documents, does not attempt to have feature parity with "},{"type":"codeVoice","code":"NSTextView"},{"text":".","type":"text"}],"url":"\/documentation\/codeedittextview\/textview","role":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView":{"role":"collection","title":"CodeEditTextView","url":"\/documentation\/codeedittextview","abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","kind":"symbol","type":"topic"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"title":"NSTextInputClient Implementations","kind":"article","abstract":[],"url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations","role":"collectionGroup","type":"topic"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"abstract":[{"text":"Returns the fraction of the distance from the left side of the character to the right side that a given point","type":"text"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint","text":"NSPoint"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"}],"url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","type":"topic","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","title":"fractionOfDistanceThroughGlyph(for:)"}}}