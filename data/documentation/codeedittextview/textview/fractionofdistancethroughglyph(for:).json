{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)"]}],"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"text":" ","type":"text"},{"text":"lies.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)"},"hierarchy":{"paths":[["doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"symbolKind":"method","title":"fractionOfDistanceThroughGlyph(for:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"kind":"text","text":"("},{"kind":"externalParam","text":"for"},{"kind":"text","text":": "},{"text":"NSPoint","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint"},{"kind":"text","text":") -> "},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"extendedModule":"CodeEditTextView","externalID":"c:@CM@CodeEditTextView@objc(cs)TextView(im)fractionOfDistanceThroughGlyphForPoint:","roleHeading":"Instance Method","modules":[{"name":"CodeEditTextView"}],"role":"symbol"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fractionOfDistanceThroughGlyph","kind":"identifier"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"point"},{"text":": ","kind":"text"},{"text":"NSPoint","preciseIdentifier":"c:@T@NSPoint","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"point","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The point to test."}]}]}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"inlineContent":[{"type":"text","text":"The fraction of the distance aPoint is through the glyph in which it lies. May be 0 or 1 if aPoint"},{"type":"text","text":" "},{"text":"is not within the bounding rectangle of a glyph (0 if the point is to the left or above the glyph;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"1 if it’s to the right or below)."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"For purposes such as dragging out a selection or placing the insertion point, a partial percentage less than or"},{"type":"text","text":" "},{"text":"equal to 0.5 indicates that aPoint should be considered as falling before the glyph; a partial percentage","type":"text"},{"text":" ","type":"text"},{"text":"greater than 0.5 indicates that it should be considered as falling after the glyph. If the nearest glyph doesn’t","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lie under aPoint at all (for example, if aPoint is beyond the beginning or end of a line), this ratio is 0 or 1."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if the glyph stream contains the glyphs “A” and “b”, with the width of “A” being 13 points, and"},{"text":" ","type":"text"},{"type":"text","text":"aPoint is 8 points from the left side of “A”, then the fraction of the distance is 8\/13, or 0.615. In this"},{"type":"text","text":" "},{"type":"text","text":"case, the aPoint should be considered as falling between “A” and “b” for purposes such as dragging out a"},{"type":"text","text":" "},{"type":"text","text":"selection or placing the insertion point."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://CodeEditTextView/documentation/CodeEditTextView":{"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView","title":"CodeEditTextView","type":"topic","abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"url":"\/documentation\/codeedittextview","role":"collection","kind":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/fractionOfDistanceThroughGlyph(for:)":{"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/fractionOfDistanceThroughGlyph(for:)","title":"fractionOfDistanceThroughGlyph(for:)","abstract":[{"type":"text","text":"Returns the fraction of the distance from the left side of the character to the right side that a given point"},{"text":" ","type":"text"},{"type":"text","text":"lies."}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fractionOfDistanceThroughGlyph"},{"text":"(","kind":"text"},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSPoint","text":"NSPoint"},{"kind":"text","text":") -> "},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"url":"\/documentation\/codeedittextview\/textview\/fractionofdistancethroughglyph(for:)","type":"topic","role":"symbol","kind":"symbol"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView/NSTextInputClient-Implementations":{"identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView\/NSTextInputClient-Implementations","title":"NSTextInputClient Implementations","role":"collectionGroup","abstract":[],"kind":"article","type":"topic","url":"\/documentation\/codeedittextview\/textview\/nstextinputclient-implementations"},"doc://CodeEditTextView/documentation/CodeEditTextView/TextView":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TextView"}],"url":"\/documentation\/codeedittextview\/textview","title":"TextView","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TextView","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/CodeEditTextView\/documentation\/CodeEditTextView\/TextView","kind":"symbol","abstract":[{"type":"text","text":"A view that draws and handles user interactions with text."},{"text":" ","type":"text"},{"text":"Optimized for line-based documents, does not attempt to have feature parity with ","type":"text"},{"code":"NSTextView","type":"codeVoice"},{"text":".","type":"text"}]}}}