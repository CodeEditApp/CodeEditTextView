{"hierarchy":{"paths":[["doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView","doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextLayoutManager"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/codeedittextview\/textlayoutmanager\/layoutlines(in:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextLayoutManager\/layoutLines(in:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"layoutLines","kind":"identifier"},{"kind":"text","text":"("},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"NSRect","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSRect"},{"text":"?) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sh","text":"Set"},{"kind":"text","text":"<"},{"text":"TextLine","kind":"typeIdentifier","preciseIdentifier":"s:16CodeEditTextView0C4LineC"},{"kind":"text","text":"."},{"text":"ID","kind":"typeIdentifier","preciseIdentifier":"s:16CodeEditTextView0C4LineC2IDa"},{"text":">","kind":"text"}],"externalID":"s:16CodeEditTextView0C13LayoutManagerC11layoutLines2inShy10Foundation4UUIDVGSo6CGRectVSg_tF","modules":[{"name":"CodeEditTextView"}],"title":"layoutLines(in:)","symbolKind":"method","role":"symbol","extendedModule":"CodeEditTextView"},"sections":[],"abstract":[{"type":"text","text":"Lays out all visible lines"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"layoutLines"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"in"},{"text":" ","kind":"text"},{"text":"rect","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"NSRect","preciseIdentifier":"c:@T@NSRect"},{"text":"? = nil) -> ","kind":"text"},{"text":"Set","kind":"typeIdentifier","preciseIdentifier":"s:Sh"},{"kind":"text","text":"<"},{"text":"TextLine","preciseIdentifier":"s:16CodeEditTextView0C4LineC","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextLine","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:16CodeEditTextView0C4LineC2IDa","text":"ID","kind":"typeIdentifier"},{"kind":"text","text":">"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview-Of-The-Layout-Routine","text":"Overview Of The Layout Routine"},{"inlineContent":[{"type":"text","text":"The basic premise of this method is that it loops over all lines in the given rect (defaults to the visible"},{"type":"text","text":" "},{"text":"rect), checks if the line needs a layout calculation, and performs layout on the line if it does.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The thing that makes this layout method so fast is the second point, checking if a line needs layout. To"},{"type":"text","text":" "},{"type":"text","text":"determine if a line needs a layout pass, the layout manager can check three things:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"1","type":"text"}],"type":"strong"},{"text":" Was the line laid out under the assumption of a different maximum layout width?","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For instance, if a line was previously broken by the line wrapping setting, it won’t need to wrap once the"},{"type":"text","text":" "},{"type":"text","text":"line wrapping is disabled. This will detect that, and cause the lines to be recalculated."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"2"}]},{"type":"text","text":" Was the line previously not visible? This is determined by keeping a set of visible line IDs. If the"},{"text":" ","type":"text"},{"text":"line does not appear in that set, we can assume it was previously off screen and may need layout.","type":"text"}]}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"3","type":"text"}],"type":"strong"},{"type":"text","text":" Was the line entirely laid out? We break up lines into line fragments. When we do layout, we determine"},{"text":" ","type":"text"},{"type":"text","text":"all line fragments but don’t necessarily place them all in the view. This checks if all line fragments have"},{"text":" ","type":"text"},{"type":"text","text":"been placed in the view. If not, we need to place them."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once it has been determined that a line needs layout, we perform layout by recalculating it’s line fragments,"},{"type":"text","text":" "},{"text":"removing all old line fragment views, and creating new ones for the line.","type":"text"}]},{"type":"heading","text":"Laziness","level":2,"anchor":"Laziness"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the end of the layout pass, we clean up any old lines by updating the set of visible line IDs and fragment"},{"type":"text","text":" "},{"text":"IDs. Any IDs that no longer appear in those sets are removed to save resources. This facilitates the text view’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ability to only render text that is visible and saves tons of resources (similar to the lazy loading of"},{"type":"text","text":" "},{"text":"collection or table views).","type":"text"}]},{"inlineContent":[{"text":"The other important lazy attribute is the line iteration. Line iteration is done lazily. As we iterate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"through lines and potentially update their heights, the next line is only queried for "},{"type":"emphasis","inlineContent":[{"type":"text","text":"after"}]},{"text":" the updates are","type":"text"},{"type":"text","text":" "},{"text":"finished.","type":"text"}],"type":"paragraph"},{"anchor":"Reentry","level":2,"type":"heading","text":"Reentry"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An important thing to note is that this method cannot be reentered. If a layout pass has begun while a layout"},{"text":" ","type":"text"},{"text":"pass is already ongoing, internal data structures will be broken. In debug builds, this is checked with a simple","type":"text"},{"text":" ","type":"text"},{"text":"boolean and assertion.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To help ensure this property, all view modifications are performed within a ","type":"text"},{"type":"codeVoice","code":"CATransaction"},{"type":"text","text":". This guarantees"},{"type":"text","text":" "},{"text":"that macOS calls ","type":"text"},{"code":"layout","type":"codeVoice"},{"type":"text","text":" on any related views only after we’ve finished inserting and removing line fragment"},{"type":"text","text":" "},{"type":"text","text":"views. Otherwise, inserting a line fragment view could trigger a layout pass prematurely and cause this method"},{"type":"text","text":" "},{"text":"to re-enter.","type":"text"}]},{"style":"warning","type":"aside","content":[{"inlineContent":[{"type":"text","text":"This is probably not what you’re looking for. If you need to invalidate layout, or update lines, this"},{"text":" ","type":"text"},{"type":"text","text":"is not the way to do so. This should only be called when macOS performs layout."}],"type":"paragraph"}],"name":"Warning"}]}],"references":{"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextLine":{"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TextLine"}],"title":"TextLine","navigatorTitle":[{"kind":"identifier","text":"TextLine"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Represents a displayable line of text."}],"url":"\/documentation\/codeedittextview\/textline","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextLine"},"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextLayoutManager/layoutLines(in:)":{"url":"\/documentation\/codeedittextview\/textlayoutmanager\/layoutlines(in:)","role":"symbol","title":"layoutLines(in:)","kind":"symbol","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextLayoutManager\/layoutLines(in:)","type":"topic","abstract":[{"type":"text","text":"Lays out all visible lines"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"layoutLines"},{"kind":"text","text":"("},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"NSRect","preciseIdentifier":"c:@T@NSRect"},{"text":"?) -> ","kind":"text"},{"preciseIdentifier":"s:Sh","text":"Set","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:16CodeEditTextView0C4LineC","text":"TextLine","kind":"typeIdentifier"},{"kind":"text","text":"."},{"preciseIdentifier":"s:16CodeEditTextView0C4LineC2IDa","text":"ID","kind":"typeIdentifier"},{"text":">","kind":"text"}]},"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView/TextLayoutManager":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TextLayoutManager"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView\/TextLayoutManager","navigatorTitle":[{"text":"TextLayoutManager","kind":"identifier"}],"type":"topic","abstract":[{"text":"The text layout manager manages laying out lines in a code document.","type":"text"}],"title":"TextLayoutManager","url":"\/documentation\/codeedittextview\/textlayoutmanager"},"doc://codeedittextview.CodeEditTextView/documentation/CodeEditTextView":{"kind":"symbol","abstract":[{"type":"text","text":"A text editor designed to edit code documents."}],"identifier":"doc:\/\/codeedittextview.CodeEditTextView\/documentation\/CodeEditTextView","type":"topic","role":"collection","title":"CodeEditTextView","url":"\/documentation\/codeedittextview"}}}