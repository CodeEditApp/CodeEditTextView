{"abstract":[{"type":"text","text":"Begins a transaction, preventing the layout manager from performing layout until the "},{"code":"endTransaction","type":"codeVoice"},{"type":"text","text":" is called."},{"type":"text","text":" "},{"type":"text","text":"Useful for grouping attribute modifications into one layout pass rather than laying out every update."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/codeedittextview\/textlayoutmanager\/begintransaction()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"extendedModule":"CodeEditTextView","externalID":"s:16CodeEditTextView0C13LayoutManagerC16beginTransactionyyF","title":"beginTransaction()","role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"beginTransaction","kind":"identifier"},{"kind":"text","text":"()"}],"modules":[{"name":"CodeEditTextView"}],"roleHeading":"Instance Method"},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginTransaction","kind":"identifier"},{"text":"()","kind":"text"}]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can nest transaction start\/end calls, the layout manager will not cause layout until the last transaction"},{"type":"text","text":" "},{"text":"group is ended.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Ensure there is a balanced number of begin\/end calls. If there is a missing endTranscaction call, the layout","type":"text"},{"type":"text","text":" "},{"type":"text","text":"manager will never lay out text. If there is a end call without matching a start call an assertionFailure"},{"text":" ","type":"text"},{"text":"will occur.","type":"text"}]}],"kind":"content"}],"hier